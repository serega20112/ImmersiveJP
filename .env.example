APP_NAME=ImmersJP
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=1
APP_BASE_URL=http://127.0.0.1:8000
LOG_LEVEL=INFO
SECRET_KEY=change-me
SESSION_SECRET=change-me-too
COOKIE_SECURE=0
COOKIE_SAMESITE=lax
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=immersjp
POSTGRES_USER=immersjp
POSTGRES_PASSWORD=immersjp
DATABASE_URL=
REDIS_ENABLED=1
REDIS_REQUIRED=0
REDIS_URL=redis://localhost:6379/0
HF_API_TOKEN=
# For the OpenAI-compatible Hugging Face Router endpoint, include the provider
# suffix directly in the model name and leave HF_PROVIDER empty.
HF_MODEL=openai/gpt-oss-120b:fireworks-ai
HF_PROVIDER=
HF_MENTOR_MODEL=openai/gpt-oss-20b:fireworks-ai
HF_MENTOR_TIMEOUT_SECONDS=8
HF_MENTOR_RETRY_ATTEMPTS=1
HF_API_URL=https://router.huggingface.co/v1/chat/completions
HF_TIMEOUT_SECONDS=12
HF_RETRY_ATTEMPTS=3
HF_RETRY_BACKOFF_SECONDS=0.8
LLM_REQUEST_LIMIT=30
LLM_REQUEST_WINDOW_SECONDS=3600
TEXT_INPUT_LIMIT=500
EMAIL_VERIFICATION_EXPIRE_MINUTES=20
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=1
